# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-32-character-hex-secret-key-here

# Initial Admin Password (will be hashed on first run)
INIT_ADMIN_PASSWORD=your-secure-password-here

# Ifdian (爱发电) Configuration
# Get these from: https://ifdian.net/dash/setwebhook
IFDIAN_TOKEN=your-ifdian-token-here
IFDIAN_USER_ID=your-ifdian-user-id-here

# Daily Free Points (default: 80)
DAILY_FREE_POINTS=80

# Registration Open (true/false)
REGISTRATION_OPEN=true
